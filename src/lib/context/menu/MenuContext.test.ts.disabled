import { describe, it, expect, jest } from '@jest/globals';
import { renderHook } from '@testing-library/react';
import { useMenu, MenuProvider } from './MenuContext';

// Mock dependencies with spies to test business logic
const mockHandleUnifiedConnect = jest.fn();
const mockLogout = jest.fn();
const mockOpenMobileBurgerMenu = jest.fn();
const mockOpenProfileModal = jest.fn();
const mockRouterPush = jest.fn();

jest.mock('@/lib/hooks/useUnifiedAuth', () => ({
  useUnifiedAuth: () => ({
    handleUnifiedConnect: mockHandleUnifiedConnect,
    logout: mockLogout,
  }),
}));

jest.mock('next/navigation', () => ({
  usePathname: () => '/',
  useRouter: () => ({
    push: mockRouterPush,
  }),
}));

jest.mock('@/lib/context/AuthContext', () => ({
  useAuth: () => ({
    isAuthenticated: false,
    user: null,
    hasRole: jest.fn(() => false),
  }),
}));

jest.mock('@/lib/context/ModalContext', () => ({
  useModal: () => ({
    openMobileBurgerMenu: mockOpenMobileBurgerMenu,
    openProfileModal: mockOpenProfileModal,
  }),
}));

jest.mock('@/app/(protected)/dashboard/contexts/dashboard-view-context', () => ({
  useDashboardView: () => ({
    currentView: 'supporter',
  }),
}));

describe.skip('MenuContext - 業務邏輯測試 (暫時跳過 - CSS module 問題)', () => {
  beforeEach(() => {
    jest.clearAllMocks();
  });

  describe('用戶操作處理', () => {
    it('connect 操作應該調用統一認證', () => {
      const { result } = renderHook(() => useMenu(), {
        wrapper: MenuProvider
      });

      result.current.handleAction('connect');

      expect(mockHandleUnifiedConnect).toHaveBeenCalledTimes(1);
    });

    it('logout 操作應該調用登出功能', () => {
      const { result } = renderHook(() => useMenu(), {
        wrapper: MenuProvider
      });

      result.current.handleAction('logout');

      expect(mockLogout).toHaveBeenCalledTimes(1);
    });

    it('openMobileBurgerMenu 操作應該打開移動端 burger 選單', () => {
      const { result } = renderHook(() => useMenu(), {
        wrapper: MenuProvider
      });

      result.current.handleAction('openMobileBurgerMenu');

      expect(mockOpenMobileBurgerMenu).toHaveBeenCalledTimes(1);
    });

    it('openProfileModal 操作應該打開個人資料 modal', () => {
      const { result } = renderHook(() => useMenu(), {
        wrapper: MenuProvider
      });

      result.current.handleAction('openProfileModal');

      expect(mockOpenProfileModal).toHaveBeenCalledTimes(1);
    });

    it('navigation 操作應該使用路由跳轉', () => {
      const { result } = renderHook(() => useMenu(), {
        wrapper: MenuProvider
      });

      result.current.handleAction('navigation', '/dashboard');

      expect(mockRouterPush).toHaveBeenCalledWith('/dashboard');
    });
  });

  describe('Menu 業務狀態', () => {
    it('未登入用戶應該看到 Connect 按鈕', () => {
      const { result } = renderHook(() => useMenu(), {
        wrapper: MenuProvider
      });

      expect(result.current.showConnectButton).toBe(true);
      expect(result.current.showProfileButton).toBe(false);
      expect(result.current.showDrops).toBe(false);
    });

    it('應該正確傳遞認證上下文', () => {
      const { result } = renderHook(() => useMenu(), {
        wrapper: MenuProvider
      });

      expect(result.current.context.isAuthenticated).toBe(false);
      expect(result.current.context.userRole).toBe(null);
    });
  });

  describe('容錯性', () => {
    it('無效的 action 不應該拋出錯誤', () => {
      const { result } = renderHook(() => useMenu(), {
        wrapper: MenuProvider
      });

      expect(() => {
        result.current.handleAction('invalid-action' as any);
      }).not.toThrow();
    });

    it('沒有 Provider 時應該提供安全的 fallback', () => {
      const { result } = renderHook(() => useMenu());

      expect(typeof result.current.handleAction).toBe('function');
      expect(() => {
        result.current.handleAction('connect');
      }).not.toThrow();
    });
  });
});